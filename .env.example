# FastAPI
FAST_API_HOST=0.0.0.0
FAST_API_PORT=8000
FAST_API_WORKERS=4
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/audio_director

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=audio_processing_queue

# Whisper & WhisperX
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=zh

# LLM API Keys
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here

# Audio Processing
DEFAULT_SAMPLE_RATE=16000
MAX_AUDIO_DURATION=3600
AUDIO_OUTPUT_FORMAT=wav
AUDIO_OUTPUT_BITRATE=128k

# Processing Strategy
DEFAULT_EDIT_STRATEGY=natural
MIN_SILENCE_DURATION=0.3
MAX_EDIT_RATIO=0.15

# File Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_FILE_SIZE=500MB

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/audio_director.log

# Performance
WORKERS=4
THREADS_PER_WORKER=2
GPU_ENABLED=true
